# ---------------------------------------------------------
# Klyo — environment configuration
# Copy this file to ".env" and fill in your own values.
# Never commit your real ".env" file to version control.
# ---------------------------------------------------------

# Port the server listens on
PORT=4000

# The public URL people use to reach the app (used for Stripe
# redirect links). For local dev, leave as-is.
APP_URL=http://localhost:4000

# Postgres connection string. On Railway, add the Postgres add-on
# and set this to ${{Postgres.DATABASE_URL}} in the service's
# Variables tab — Railway fills in the real value automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/klyo

# Long random string used to sign login sessions (tokens).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# --- OpenAI (used by the "Generate with AI" button) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4-mini

# --- Gmail sign-in (lets each workspace connect their own Gmail
# account instead of typing an SMTP password) ---
# Set up at console.cloud.google.com — see README for exact steps.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Outgoing email fallback (used only if a workspace hasn't
# connected Gmail) ---
# Standard SMTP settings — works with Gmail, Outlook, SendGrid, etc.
# Optional: leave blank if every workspace will connect their own Gmail.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password-or-app-password
SMTP_FROM_NAME=Klyo
SMTP_FROM_EMAIL=your-email@example.com

# --- Stripe (used for monthly subscriptions) ---
# Create one Product per tier in your Stripe Dashboard, each with a
# recurring monthly Price, then fill in the price IDs below. Leave a
# tier blank to hide it from the pricing modal until it's ready.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PRICE_ID_PERSONAL=price_personal_id_here
STRIPE_PRICE_ID_PLUS=price_plus_id_here
STRIPE_PRICE_ID_PRO=price_pro_id_here
STRIPE_PRICE_ID_ULTRA=price_ultra_id_here
# Optional: a one-time (non-renewing) Price per tier, same amount as
# above but created as a one-off Price in Stripe instead of recurring.
# Leave any of these blank to simply not offer that "buy 1 month, no
# auto-renew" option for that tier.
STRIPE_PRICE_ID_PERSONAL_ONETIME=price_personal_onetime_id_here
STRIPE_PRICE_ID_PLUS_ONETIME=price_plus_onetime_id_here
STRIPE_PRICE_ID_PRO_ONETIME=price_pro_onetime_id_here
STRIPE_PRICE_ID_ULTRA_ONETIME=price_ultra_onetime_id_here
# Created when you add a webhook endpoint in the Stripe Dashboard
# pointing at https://your-domain.com/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Platform admin (you, the developer — not a workspace admin) ---
# Whichever email matches this gets access to the hidden /platform
# dashboard: every workspace, every user, signups, estimated revenue.
# Leave this set to your own login email.
PLATFORM_ADMIN_EMAIL=you@example.com
